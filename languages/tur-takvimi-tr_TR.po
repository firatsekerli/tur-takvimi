msgid "Enter your postcode to find the nearest stop and date"
msgstr "En yakın durağı ve tarihi bulmak için posta kodunuzu girin"

msgid "Your postcode"
msgstr "Posta kodunuz"

msgid "Search"
msgstr "Ara"

msgid "Searching…"
msgstr "Aranıyor…"

