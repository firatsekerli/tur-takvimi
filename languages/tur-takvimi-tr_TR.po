msgstr "Şehri Düzenle"

msgid "Search Locations"
msgstr "Şehirlerde Ara"

msgid "Routes"
msgstr "Rotalar"

msgid "Route"
msgstr "Rota"

msgid "Add Route"
msgstr "Rota Ekle"

msgid "Edit Route"
msgstr "Rotayı Düzenle"

