msgstr "Tur Takvimi"

msgid "Tur Takvimi — Settings"
msgstr "Tur Takvimi — Ayarlar"

#. Post type & taxonomy labels
msgid "Locations"
msgstr "Şehirler"

msgid "Location"
msgstr "Şehir"

